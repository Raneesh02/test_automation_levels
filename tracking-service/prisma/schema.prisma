datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

model TrackingRecord {
  id        String   @id @default(uuid())
  orderId   String
  status    String
  latitude  Float?
  longitude Float?
  note      String?
  createdAt DateTime @default(now())
}
