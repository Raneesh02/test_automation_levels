{
  "consumer": {
    "name": "order-service"
  },
  "interactions": [
    {
      "description": "a request to create a tracking record for an order",
      "providerStates": [
        {
          "name": "no existing tracking records"
        }
      ],
      "request": {
        "body": {
          "orderId": "order-123"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "method": "POST",
        "path": "/tracking"
      },
      "response": {
        "body": {
          "id": "some-uuid",
          "orderId": "order-123",
          "status": "PENDING"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.orderId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 201
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.3.0"
    },
    "pactRust": {
      "ffi": "0.5.3",
      "models": "1.3.9"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "tracking-service"
  }
}