datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

model Order {
  id         String      @id @default(uuid())
  status     OrderStatus @default(PENDING)
  weightKg   Float
  distanceKm Float
  priority   Priority
  totalPrice Float
  courierId  String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

enum OrderStatus {
  PENDING
  ASSIGNED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum Priority {
  standard
  express
  overnight
}
